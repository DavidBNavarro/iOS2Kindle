{
  "manifest_version": 3,
  "name": "Web2Kindle",
  "version": "1.0.0",
  "description": "Send web articles to Kindle-friendly EPUBs",
  "key": "",
  "permissions": [
    "activeTab",
    "contextMenus",
    "notifications",
    "scripting",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "oauth2": {
    "client_id": "765612042964-6fme7cj065c025amt81pslggkcnq6ckn.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/gmail.send", "https://www.googleapis.com/auth/gmail.metadata"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
